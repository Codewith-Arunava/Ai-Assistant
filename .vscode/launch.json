{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Gubluu: Run",
            "type": "debugpy",
            "request": "launch",
            "module": "gubluu",
            "args": ["--version"],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Gubluu: Chat (CLI)",
            "type": "debugpy",
            "request": "launch",
            "module": "gubluu",
            "args": ["chat"],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Pytest: All Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["-v", "--tb=short"],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal"
        }
    ]
}
