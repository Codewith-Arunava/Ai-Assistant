# ─────────────────────────────────────────────
# Gubluu — .gitignore
# ─────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
*.swp
*.swo
*~

# VS Code (keep settings, ignore user-specific)
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Runtime data (databases, models, caches, logs)
data/

# Environment variables (NEVER commit secrets)
.env
.env.*
!.env.example

# Test artifacts
.coverage
htmlcov/
.pytest_cache/

# mypy
.mypy_cache/

# ruff
.ruff_cache/

# Distribution
*.spec

# Model weights (large binary files)
*.bin
*.pt
*.onnx
*.safetensors

# Audio recordings (dev testing)
*.wav
*.mp3
*.ogg

# Pre-commit
.pre-commit-cache/
